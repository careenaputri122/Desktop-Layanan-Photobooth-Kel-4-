<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.geometry.Insets?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.KalenderBookingController"
      prefWidth="1280" prefHeight="800"
      styleClass="admin-root">

    <!-- ══════════════════════════════════════
         SIDEBAR KIRI
         ══════════════════════════════════════ -->
    <VBox styleClass="sidebar" prefWidth="240" minWidth="240" spacing="0">

        <!-- Logo -->
        <VBox styleClass="sidebar-logo-box" alignment="CENTER_LEFT" spacing="4">
            <Label text="Aksaf" styleClass="sidebar-logo-text"/>
            <Label text="Photobooth" styleClass="sidebar-logo-sub"/>
        </VBox>

        <Separator styleClass="sidebar-sep"/>

        <!-- Label Seksi -->
        <Label text="MENU UTAMA" styleClass="sidebar-section-label">
            <VBox.margin><Insets top="20" left="20" bottom="8" right="0"/></VBox.margin>
        </Label>

        <!-- Dashboard -->
        <HBox styleClass="sidebar-menu-item" alignment="CENTER_LEFT" spacing="12"
              onMouseClicked="#goDashboard">
            <Label text="Dashboard" styleClass="sidebar-menu-label"/>
        </HBox>

        <!-- Kelola Pesanan -->
        <HBox styleClass="sidebar-menu-item" alignment="CENTER_LEFT" spacing="12"
              onMouseClicked="#goKelolaPesanan">
            <Label text="Kelola Pesanan" styleClass="sidebar-menu-label"/>
        </HBox>

        <!-- Kelola Paket -->
        <HBox styleClass="sidebar-menu-item" alignment="CENTER_LEFT" spacing="12"
              onMouseClicked="#goKelolaPaket">
            <Label text="Kelola Paket" styleClass="sidebar-menu-label"/>
        </HBox>

        <!-- Upload Galeri -->
        <HBox styleClass="sidebar-menu-item" alignment="CENTER_LEFT" spacing="12"
              onMouseClicked="#goUploadGaleri">
            <Label text="Upload Galeri" styleClass="sidebar-menu-label"/>
        </HBox>

        <!-- Kalender Booking (AKTIF) -->
        <HBox styleClass="sidebar-menu-item-active" alignment="CENTER_LEFT" spacing="12">
            <Label text="Kalender Booking" styleClass="sidebar-menu-label"/>
        </HBox>

        <!-- Pelanggan -->
        <HBox styleClass="sidebar-menu-item" alignment="CENTER_LEFT" spacing="12"
              onMouseClicked="#goPelanggan">
            <Label text="Pelanggan" styleClass="sidebar-menu-label"/>
        </HBox>

        <Button text="Logout"
                onAction="#handleLogout"
                styleClass="sidebar-logout-btn"
                maxWidth="Infinity"/>

        <!-- Spacer -->
        <Region VBox.vgrow="ALWAYS"/>

        <!-- Bottom: Profile -->
        <VBox styleClass="sidebar-bottom-section" spacing="0">
            <Separator styleClass="sidebar-sep"/>
            <HBox styleClass="sidebar-profile-box" alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="sidebar-avatar" minWidth="36" minHeight="36"
                           prefWidth="36" prefHeight="36">
                    <Label fx:id="labelAdminInitial" styleClass="sidebar-avatar-initial"/>
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="labelAdminName" text="Admin" styleClass="sidebar-profile-name"/>
                    <Label fx:id="labelAdminRole" text="Administrator" styleClass="sidebar-profile-role"/>
                </VBox>
            </HBox>
        </VBox>

    </VBox>

    <!-- ══════════════════════════════════════
         KONTEN UTAMA
         ══════════════════════════════════════ -->
    <HBox HBox.hgrow="ALWAYS" spacing="0">

        <!-- KIRI: Kalender -->
        <ScrollPane HBox.hgrow="ALWAYS" fitToWidth="true" hbarPolicy="NEVER"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox styleClass="main-content" spacing="0">

                <!-- Header -->
                <VBox styleClass="content-header" spacing="4">
                    <Label text="Kalender Booking" styleClass="page-title"/>
                    <Label text="Lihat ketersediaan tanggal event dan detail pesanan."
                           styleClass="page-subtitle"/>
                </VBox>

                <!-- Kalender Section -->
                <VBox spacing="16">
                    <VBox.margin><Insets top="28" right="32" bottom="32" left="32"/></VBox.margin>

                    <!-- Card Kalender -->
                    <VBox styleClass="table-section" spacing="0">

                        <!-- Header Kalender: Prev | Bulan Tahun | Next -->
                        <HBox alignment="CENTER" spacing="16" style="-fx-padding: 0 0 16 0;">
                            <Button text="&#8249;" onAction="#prevMonth" styleClass="cal-nav-btn"/>
                            <Label fx:id="labelBulanTahun" text="Mei 2026" styleClass="cal-month-label"
                                   HBox.hgrow="ALWAYS" alignment="CENTER"/>
                            <Button text="&#8250;" onAction="#nextMonth" styleClass="cal-nav-btn"/>
                        </HBox>

                        <Separator style="-fx-background-color: #F3F4F6;"/>

                        <!-- Grid Kalender -->
                        <GridPane fx:id="calendarGrid" hgap="6" vgap="6"
                                  style="-fx-padding: 16 0 8 0;" maxWidth="Infinity"/>

                        <!-- Legend -->
                        <HBox spacing="20" alignment="CENTER_LEFT"
                              style="-fx-padding: 16 0 4 0;">
                            <HBox spacing="6" alignment="CENTER_LEFT">
                                <StackPane minWidth="14" minHeight="14" prefWidth="14" prefHeight="14"
                                           style="-fx-background-color: white; -fx-background-radius: 3; -fx-border-color: #E5E7EB; -fx-border-radius: 3; -fx-border-width: 1;"/>
                                <Label text="Tersedia" style="-fx-font-size: 11px; -fx-text-fill: #6B7280;"/>
                            </HBox>
                            <HBox spacing="6" alignment="CENTER_LEFT">
                                <StackPane minWidth="14" minHeight="14" prefWidth="14" prefHeight="14"
                                           style="-fx-background-color: #FDE8F4; -fx-background-radius: 3; -fx-border-color: #FBCFE8; -fx-border-radius: 3; -fx-border-width: 1;"/>
                                <Label text="Sudah Dipesan" style="-fx-font-size: 11px; -fx-text-fill: #6B7280;"/>
                            </HBox>
                            <HBox spacing="6" alignment="CENTER_LEFT">
                                <StackPane minWidth="14" minHeight="14" prefWidth="14" prefHeight="14"
                                           style="-fx-background-color: #F3F4F6; -fx-background-radius: 3; -fx-border-color: #E5E7EB; -fx-border-radius: 3; -fx-border-width: 1;"/>
                                <Label text="Di Luar Bulan" style="-fx-font-size: 11px; -fx-text-fill: #6B7280;"/>
                            </HBox>
                            <HBox spacing="6" alignment="CENTER_LEFT">
                                <StackPane minWidth="14" minHeight="14" prefWidth="14" prefHeight="14"
                                           style="-fx-background-color: white; -fx-background-radius: 3; -fx-border-color: #EC4899; -fx-border-radius: 3; -fx-border-width: 2;"/>
                                <Label text="Hari Ini" style="-fx-font-size: 11px; -fx-text-fill: #6B7280;"/>
                            </HBox>
                        </HBox>

                    </VBox>
                </VBox>

            </VBox>
        </ScrollPane>

        <!-- KANAN: Panel Detail Booking -->
        <VBox fx:id="detailPanel" prefWidth="300" minWidth="280" maxWidth="320"
              style="-fx-background-color: white; -fx-border-color: #E5E7EB; -fx-border-width: 0 0 0 1;">

            <!-- Header Panel -->
            <HBox alignment="CENTER_LEFT"
                  style="-fx-background-color: white; -fx-padding: 20 16 16 16; -fx-border-color: #F3F4F6; -fx-border-width: 0 0 1 0;">
                <Label fx:id="detailTitle" text="Detail Booking"
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
            </HBox>

            <!-- Konten detail (scrollable) -->
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: white; -fx-background: white;">
                <VBox fx:id="detailContent" spacing="8"
                      style="-fx-padding: 16 12 16 12; -fx-background-color: white;"/>
            </ScrollPane>

        </VBox>

    </HBox>

</HBox>
