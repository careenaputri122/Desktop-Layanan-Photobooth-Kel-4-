<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Separator?>

<AnchorPane
    xmlns:fx="http://javafx.com/fxml"
    fx:controller="controller.RegisterController"
    styleClass="root-pane">

    <VBox
        AnchorPane.topAnchor="0"
        AnchorPane.bottomAnchor="0"
        AnchorPane.leftAnchor="0"
        AnchorPane.rightAnchor="0"
        alignment="CENTER">

        <VBox styleClass="card" spacing="16" maxWidth="370" minWidth="370">

            <VBox spacing="4" alignment="CENTER">
                <Label text="&#128247;" styleClass="logo-emoji"/>
                <Label text="Buat Akun Baru" styleClass="app-title"/>
                <Label text="Isi data diri untuk mendaftar" styleClass="app-subtitle"/>
            </VBox>

            <Separator/>

            <VBox spacing="12">

                <HBox spacing="10">
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="Nama Depan" styleClass="field-label"/>
                        <TextField
                            fx:id="namaDepanField"
                            promptText="Nama depan"
                            styleClass="input-field"
                            maxWidth="Infinity"/>
                    </VBox>
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="Nama Belakang" styleClass="field-label"/>
                        <TextField
                            fx:id="namaBelakangField"
                            promptText="Nama belakang"
                            styleClass="input-field"
                            maxWidth="Infinity"/>
                    </VBox>
                </HBox>

                <VBox spacing="5">
                    <Label text="Email" styleClass="field-label"/>
                    <TextField
                        fx:id="emailField"
                        promptText="contoh@email.com"
                        styleClass="input-field"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Password" styleClass="field-label"/>
                    <PasswordField
                        fx:id="passwordField"
                        promptText="Minimal 6 karakter"
                        styleClass="input-field"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Konfirmasi Password" styleClass="field-label"/>
                    <PasswordField
                        fx:id="confirmPasswordField"
                        promptText="Ulangi password kamu"
                        styleClass="input-field"/>
                </VBox>

            </VBox>

            <Label fx:id="errorLabel" text="" wrapText="true" minHeight="16"/>

            <Button
                text="Daftar Sekarang"
                onAction="#handleRegister"
                styleClass="btn-primary"
                maxWidth="Infinity"/>

            <HBox alignment="CENTER" spacing="4">
                <Label text="Sudah punya akun?" styleClass="link-muted"/>
                <Hyperlink text="Masuk di sini" onAction="#goToLogin" styleClass="link-action"/>
            </HBox>

        </VBox>
    </VBox>
</AnchorPane>
