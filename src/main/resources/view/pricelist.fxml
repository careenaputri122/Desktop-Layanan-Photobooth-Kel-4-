                                <Label text="-15%" styleClass="price-discount-badge"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="Rp2.337.500" styleClass="price-final"/>
                                <Label text="Member" styleClass="price-member-badge"/>
                            </HBox>
                        </VBox>
                        <Button text="Pesan Paket" styleClass="btn-pesan" onAction="#pesanPaket"/>
                    </VBox>
                </VBox>

            </HBox>

            <!-- Baris 2: Digital, AI, Add-on -->
            <HBox fx:id="rowLainnya" spacing="20" alignment="CENTER">

                <!-- Paket Digital -->
                <VBox styleClass="paket-card" spacing="0">
                    <VBox styleClass="card-img-placeholder"
                          style="-fx-background-color: #E8EEFA;" alignment="CENTER">
                        <Label text="💻" style="-fx-font-size: 60px;"/>
                    </VBox>
                    <VBox spacing="12" style="-fx-padding: 20 20 20 20;">
                        <Label text="Tanpa Cetak" styleClass="badge-digital"/>
                        <Label text="Paket Digital" styleClass="paket-name"/>
                        <VBox spacing="6">
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="✅" styleClass="feature-check"/>
                                <Label text="3 jam operasional" styleClass="feature-text"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="✅" styleClass="feature-check"/>
                                <Label text="Backdrop 2 pilihan" styleClass="feature-text"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="✅" styleClass="feature-check"/>
                                <Label text="Props standar 20 pcs" styleClass="feature-text"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="✅" styleClass="feature-check"/>
                                <Label text="Digital file semua foto" styleClass="feature-text"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="✅" styleClass="feature-check"/>
                                <Label text="Share via QR Code" styleClass="feature-text"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="✅" styleClass="feature-check"/>
                                <Label text="1 operator profesional" styleClass="feature-text"/>
                            </HBox>
                        </VBox>
                        <VBox spacing="6">
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="Rp1.250.000" styleClass="price-original"/>
                                <Label text="-15%" styleClass="price-discount-badge"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="Rp1.062.500" styleClass="price-final"/>
                                <Label text="Member" styleClass="price-member-badge"/>
                            </HBox>
                        </VBox>
                        <Button text="Pesan Paket" styleClass="btn-pesan" onAction="#pesanPaket"/>
                    </VBox>
                </VBox>

                <!-- Paket AI Photobooth -->
                <VBox styleClass="paket-card" spacing="0">
                    <VBox styleClass="card-img-placeholder"
                          style="-fx-background-color: #1E1B4B;" alignment="CENTER">
                        <Label text="🤖" style="-fx-font-size: 60px;"/>
                    </VBox>
                    <VBox spacing="12" style="-fx-padding: 20 20 20 20;">
                        <Label text="AI" styleClass="badge-ai"/>
                        <Label text="Paket AI Photobooth" styleClass="paket-name"/>
                        <VBox spacing="6">
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="✅" styleClass="feature-check"/>
                                <Label text="4 jam operasional" styleClass="feature-text"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="✅" styleClass="feature-check"/>
                                <Label text="AI background replacement" styleClass="feature-text"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="✅" styleClass="feature-check"/>
                                <Label text="Filter &amp; efek AI real-time" styleClass="feature-text"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="✅" styleClass="feature-check"/>
                                <Label text="Digital file semua foto" styleClass="feature-text"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="✅" styleClass="feature-check"/>
                                <Label text="Share instan via WhatsApp" styleClass="feature-text"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="✅" styleClass="feature-check"/>
                                <Label text="2 operator teknisi" styleClass="feature-text"/>
                            </HBox>
                        </VBox>
                        <VBox spacing="6">
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="Rp3.500.000" styleClass="price-original"/>
                                <Label text="-15%" styleClass="price-discount-badge"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="Rp2.975.000" styleClass="price-final"/>
                                <Label text="Member" styleClass="price-member-badge"/>
                            </HBox>
                        </VBox>
                        <Button text="Pesan Paket" styleClass="btn-pesan" onAction="#pesanPaket"/>
                    </VBox>
                </VBox>

                <!-- Add-on Backdrop -->
                <VBox styleClass="paket-card" spacing="0">
                    <VBox styleClass="card-img-placeholder"
                          style="-fx-background-color: #FFF1F2;" alignment="CENTER">
                        <Label text="🌹" style="-fx-font-size: 60px;"/>
                    </VBox>
                    <VBox spacing="12" style="-fx-padding: 20 20 20 20;">
                        <Label text="Add-on" styleClass="badge-addon"/>
                        <Label text="Add-on Backdrop" styleClass="paket-name"/>
                        <VBox spacing="6">
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="✅" styleClass="feature-check"/>
                                <Label text="Tambah 1 backdrop tema" styleClass="feature-text"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="✅" styleClass="feature-check"/>
                                <Label text="Pilihan 20+ desain" styleClass="feature-text"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="✅" styleClass="feature-check"/>
                                <Label text="Ukuran 2×2 meter" styleClass="feature-text"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="✅" styleClass="feature-check"/>
                                <Label text="Termasuk frame standing" styleClass="feature-text"/>
                            </HBox>
                        </VBox>
                        <VBox spacing="6">
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="Rp350.000" styleClass="price-original"/>
                                <Label text="-15%" styleClass="price-discount-badge"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="Rp297.500" styleClass="price-final"/>
                                <Label text="Member" styleClass="price-member-badge"/>
                            </HBox>
                        </VBox>
                        <Button text="Pesan Paket" styleClass="btn-pesan" onAction="#pesanPaket"/>
                    </VBox>
                </VBox>

            </HBox>
        </VBox>

        <!-- ══════════════════════════════════════
             FOOTER
             ══════════════════════════════════════ -->
        <VBox styleClass="footer" spacing="32">
            <HBox spacing="0" alignment="TOP_LEFT">
                <VBox spacing="14" prefWidth="220" minWidth="220">
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="📷" style="-fx-font-size: 20px;"/>
                        <Label text="Aksaf Photobooth" styleClass="footer-brand"/>
                    </HBox>
                    <Label text="Sewa photobooth terjangkau untuk momen spesialmu. Operator profesional, hasil foto berkualitas, kenangan tak terlupakan."
                        styleClass="footer-tagline" wrapText="true" maxWidth="180"/>
                    <HBox spacing="8">
                        <Button text="📸" styleClass="footer-icon-btn"/>
                        <Button text="▶"  styleClass="footer-icon-btn"/>
                        <Button text="ⓕ"  styleClass="footer-icon-btn"/>
                        <Button text="✕"  styleClass="footer-icon-btn"/>
                    </HBox>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <VBox spacing="10" prefWidth="160">
                    <Label text="LINK CEPAT" styleClass="footer-heading"/>
                    <Button text="Beranda"         styleClass="footer-link" onAction="#goHome"/>
                    <Button text="Pricelist"        styleClass="footer-link"/>
                    <Button text="Galeri Foto"      styleClass="footer-link" onAction="#goGaleri"/>
                    <Button text="Kalender Booking" styleClass="footer-link" onAction="#goPemesanan"/>
                    <Button text="Area Member"      styleClass="footer-link" onAction="#goMember"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <VBox spacing="10" prefWidth="180">
                    <Label text="LAYANAN" styleClass="footer-heading"/>
                    <Button text="Photobooth Wedding"     styleClass="footer-link"/>
                    <Button text="Photobooth Ulang Tahun" styleClass="footer-link"/>
                    <Button text="Photobooth Wisuda"      styleClass="footer-link"/>
                    <Button text="Photobooth Corporate"   styleClass="footer-link"/>
                    <Button text="AI Photobooth"          styleClass="footer-link"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <VBox spacing="10" prefWidth="220">
                    <Label text="KONTAK" styleClass="footer-heading"/>
                    <Label text="📍  Jl. Kebon Jeruk Raya No. 12,&#10;     Jakarta Barat, DKI Jakarta 11530"
                        styleClass="footer-tagline" wrapText="true"/>
                    <Label text="💬  +62 812-3456-7890" styleClass="footer-tagline"/>
                    <Label text="✉   halo@fotoimoet.id"  styleClass="footer-tagline"/>
                    <Label text="🕐  Senin–Minggu, 08.00–20.00 WIB" styleClass="footer-tagline"/>
                </VBox>
            </HBox>
            <Region styleClass="footer-divider" maxWidth="Infinity"/>
            <HBox alignment="CENTER_LEFT">
                <Label text="© 2026 Aksaf Photobooth. Semua hak dilindungi." styleClass="footer-copy"/>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox spacing="4" alignment="CENTER_RIGHT">
                    <Label text="Dibuat dengan" styleClass="footer-made-with"/>
                    <Label text="♥" styleClass="footer-heart"/>
                    <Label text="untuk mengabadikan momen spesialmu" styleClass="footer-made-with"/>
                </HBox>
            </HBox>
