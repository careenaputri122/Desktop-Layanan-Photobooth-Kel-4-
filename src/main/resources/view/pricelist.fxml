<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.geometry.Insets?>

<ScrollPane
    xmlns:fx="http://javafx.com/fxml"
    fx:controller="controller.PricelistController"
    fitToWidth="true"
    hbarPolicy="NEVER"
    stylesheets="@pricelist.css"
    style="-fx-background-color: transparent; -fx-background: transparent;">

    <VBox spacing="0">

        <!-- ══════════════════════════════════════
             NAVBAR
             ══════════════════════════════════════ -->
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="0">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="📷" styleClass="navbar-logo-icon"/>
                <Label text="📷 Aksaf Photobooth" styleClass="navbar-brand"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox alignment="CENTER" spacing="4">
                <Button text="Beranda"   styleClass="nav-link"        onAction="#goHome"/>
                <Button text="Pricelist" styleClass="nav-link-active"/>
                <Button text="Galeri"    styleClass="nav-link"        onAction="#goGaleri"/>
                <Button text="Pemesanan" styleClass="nav-link"        onAction="#goPemesanan"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox alignment="CENTER_RIGHT" spacing="12">
                <Button text="Login"  styleClass="btn-masuk"    onAction="#goLogin"/>
                <Button text="Sign in"  styleClass="btn-masuk"    onAction="#goSignin"/>
            </HBox>
        </HBox>

        <!-- ══════════════════════════════════════
             HERO HEADER
             ══════════════════════════════════════ -->
        <VBox styleClass="hero-header" spacing="14" alignment="CENTER">
            <Label text="Pilih Paket Terbaik Untukmu" styleClass="hero-title"/>
            <Label
                text="Semua paket sudah termasuk operator profesional."
                styleClass="hero-subtitle"
                maxWidth="500"/>
        </VBox>

        <!-- ══════════════════════════════════════
             PAKET GRID
             ══════════════════════════════════════ -->
        <VBox styleClass="section-paket" spacing="20">

            <!-- Baris 1: Cetak -->
            <HBox fx:id="rowCetak" spacing="20" alignment="CENTER">

                <!-- Paket Starter -->
                <VBox styleClass="paket-card" spacing="0">
                    <VBox styleClass="card-img-placeholder"
                          style="-fx-background-color: #F3E8E0;" alignment="CENTER">
                        <Label text="📸" style="-fx-font-size: 60px;"/>
                    </VBox>
                    <VBox spacing="12" style="-fx-padding: 20 20 20 20;">
                        <Label text="Cetak" styleClass="badge-cetak"/>
                        <Label text="Paket Starter" styleClass="paket-name"/>
                        <VBox spacing="6">
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="✅" styleClass="feature-check"/>
                                <Label text="3 jam operasional" styleClass="feature-text"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="✅" styleClass="feature-check"/>
                                <Label text="Backdrop polos 1 pilihan" styleClass="feature-text"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="✅" styleClass="feature-check"/>
                                <Label text="Props standar 20 pcs" styleClass="feature-text"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="✅" styleClass="feature-check"/>
                                <Label text="Cetak 4R unlimited" styleClass="feature-text"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="✅" styleClass="feature-check"/>
                                <Label text="1 operator profesional" styleClass="feature-text"/>
                            </HBox>
                        </VBox>
                        <VBox spacing="6">
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="Rp1.500.000" styleClass="price-original"/>
                                <Label text="-15%" styleClass="price-discount-badge"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="Rp1.275.000" styleClass="price-final"/>
                                <Label text="Member" styleClass="price-member-badge"/>
                            </HBox>
                        </VBox>
                        <Button text="Pesan Paket" styleClass="btn-pesan" onAction="#pesanPaket"/>
                    </VBox>
                </VBox>

                <!-- Paket Silver (TERLARIS) -->
                <VBox styleClass="paket-card" spacing="0">
                    <StackPane alignment="TOP_RIGHT">
                        <VBox styleClass="card-img-placeholder"
                              style="-fx-background-color: #F9D4DF;" alignment="CENTER">
                            <Label text="🌸" style="-fx-font-size: 60px;"/>
                        </VBox>
                        <Label text="🔥 TERLARIS" styleClass="badge-terlaris"
                               style="-fx-translate-x: -12; -fx-translate-y: 12;"/>
                    </StackPane>
                    <VBox spacing="12" style="-fx-padding: 20 20 20 20;">
                        <Label text="Cetak" styleClass="badge-cetak"/>
                        <Label text="Paket Silver" styleClass="paket-name"/>
                        <VBox spacing="6">
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="✅" styleClass="feature-check"/>
                                <Label text="4 jam operasional" styleClass="feature-text"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="✅" styleClass="feature-check"/>
                                <Label text="Backdrop pilihan 3 tema" styleClass="feature-text"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="✅" styleClass="feature-check"/>
                                <Label text="Props premium 40 pcs" styleClass="feature-text"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="✅" styleClass="feature-check"/>
                                <Label text="Cetak 4R unlimited" styleClass="feature-text"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="✅" styleClass="feature-check"/>
                                <Label text="Digital file semua foto" styleClass="feature-text"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="✅" styleClass="feature-check"/>
                                <Label text="1 operator + asisten" styleClass="feature-text"/>
                            </HBox>
                        </VBox>
                        <VBox spacing="6">
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="Rp2.000.000" styleClass="price-original"/>
                                <Label text="-15%" styleClass="price-discount-badge"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="Rp1.700.000" styleClass="price-final"/>
                                <Label text="Member" styleClass="price-member-badge"/>
                            </HBox>
                        </VBox>
                        <Button text="Pesan Paket" styleClass="btn-pesan" onAction="#pesanPaket"/>
                    </VBox>
                </VBox>

                <!-- Paket Gold -->
