                    <VBox styleClass="card-img-placeholder"
                          style="-fx-background-color: #F5E6D0;" alignment="CENTER">
                        <Label text="💐" style="-fx-font-size: 60px;"/>
                    </VBox>
                    <VBox spacing="12" style="-fx-padding: 20 20 20 20;">
                        <Label text="Cetak" styleClass="badge-cetak"/>
                        <Label text="Paket Gold" styleClass="paket-name"/>
                        <VBox spacing="6">
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="✅" styleClass="feature-check"/>
                                <Label text="5 jam operasional" styleClass="feature-text"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="✅" styleClass="feature-check"/>
                                <Label text="Backdrop custom tema" styleClass="feature-text"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="✅" styleClass="feature-check"/>
                                <Label text="Props premium 60 pcs" styleClass="feature-text"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="✅" styleClass="feature-check"/>
                                <Label text="Cetak 4R + 2R unlimited" styleClass="feature-text"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
