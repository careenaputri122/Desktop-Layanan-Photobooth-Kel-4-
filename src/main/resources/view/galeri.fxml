<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<ScrollPane
    xmlns:fx="http://javafx.com/fxml"
    fx:controller="controller.GaleriController"
    fitToWidth="true"
    hbarPolicy="NEVER"
    styleClass="root-scroll"
    stylesheets="@galeri.css">

    <VBox spacing="0">

        <!-- ══════════════════════════════════════
             NAVBAR
             ══════════════════════════════════════ -->
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="0">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="📷" styleClass="navbar-logo-icon"/>
                <Label text="Aksaf Photobooth" styleClass="navbar-brand"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox alignment="CENTER" spacing="4">
                <Button text="Beranda"   styleClass="nav-link"        onAction="#goHome"/>
                <Button text="Pricelist" styleClass="nav-link"        onAction="#goPricelist"/>
                <Button text="Galeri"    styleClass="nav-link-active" onAction="#goGaleri"/>
                <Button text="Pemesanan" styleClass="nav-link"        onAction="#goPemesanan"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox fx:id="authBox" alignment="CENTER_RIGHT" spacing="12"/>
        </HBox>

        <!-- ══════════════════════════════════════
             HEADER
             ══════════════════════════════════════ -->
        <VBox styleClass="gallery-header" alignment="CENTER" spacing="12">
            <padding><Insets top="50" bottom="30" left="20" right="20"/></padding>

            <Label text="Portfolio Kami" styleClass="badge-portfolio"/>
            <Label text="Galeri Foto Event" styleClass="gallery-title"/>
            <Label text="Momen spesial yang telah kami abadikan bersama pelanggan setia Aksaf Photobooth."
                   styleClass="gallery-subtitle"
                   wrapText="true"
                   textAlignment="CENTER"
                   maxWidth="500"/>

            <!-- Search + Filter -->
            <HBox spacing="10" alignment="CENTER">
                <padding><Insets top="16"/></padding>
                <TextField fx:id="searchField"
                           promptText="🔍  Cari nama event..."
                           styleClass="search-box"
                           onKeyReleased="#onSearch"/>
                <Button fx:id="btnSemua"     text="Semua"     styleClass="filter-active" onAction="#filterSemua"/>
                <Button fx:id="btnWedding"   text="Wedding"   styleClass="filter-btn"    onAction="#filterWedding"/>
                <Button fx:id="btnBirthday"  text="Birthday"  styleClass="filter-btn"    onAction="#filterBirthday"/>
                <Button fx:id="btnCorporate" text="Corporate" styleClass="filter-btn"    onAction="#filterCorporate"/>
                <Button fx:id="btnWisuda"    text="Wisuda"    styleClass="filter-btn"    onAction="#filterWisuda"/>
            </HBox>
        </VBox>

        <!-- ══════════════════════════════════════
             GALLERY GRID
             TilePane: semua tile SERAGAM 260x195
             prefColumns=4, hgap=16, vgap=16
             ══════════════════════════════════════ -->
        <VBox styleClass="gallery-body" alignment="CENTER">
            <padding><Insets top="24" bottom="48" left="60" right="60"/></padding>

            <TilePane fx:id="galleryPane"
                      prefColumns="4"
                      prefTileWidth="260"
                      prefTileHeight="195"
                      hgap="16"
                      vgap="16"
                      alignment="CENTER"
                      styleClass="tile-pane">
            </TilePane>
        </VBox>

        <!-- ══════════════════════════════════════
             FOOTER
             ══════════════════════════════════════ -->
        <HBox styleClass="footer" spacing="60" alignment="TOP_LEFT">
            <padding><Insets top="50" bottom="50" left="80" right="80"/></padding>

            <!-- Brand -->
            <VBox spacing="12" HBox.hgrow="ALWAYS" maxWidth="220">
                <Label text="📷 Aksaf Photobooth" styleClass="footer-brand"/>
                <Label text="Sewa photobooth terjangkau untuk momen spesialmu. Operator profesional, hasil foto berkualitas, kenangan tak terlupakan."
                       styleClass="footer-desc" wrapText="true"/>
                <HBox spacing="10">
                    <Button text="ig" styleClass="social-btn"/>
                    <Button text="fb" styleClass="social-btn"/>
                    <Button text="tw" styleClass="social-btn"/>
                    <Button text="X"  styleClass="social-btn"/>
                </HBox>
            </VBox>

            <!-- Link Cepat -->
            <VBox spacing="10" HBox.hgrow="ALWAYS">
                <Label text="LINK CEPAT"       styleClass="footer-heading"/>
                <Label text="Beranda"          styleClass="footer-link"/>
                <Label text="Pricelist"        styleClass="footer-link"/>
                <Label text="Galeri Foto"      styleClass="footer-link"/>
                <Label text="Kalender Booking" styleClass="footer-link"/>
                <Label text="Area Member"      styleClass="footer-link"/>
            </VBox>

            <!-- Layanan -->
            <VBox spacing="10" HBox.hgrow="ALWAYS">
                <Label text="LAYANAN"                    styleClass="footer-heading"/>
                <Label text="Photobooth Wedding"         styleClass="footer-link"/>
                <Label text="Photobooth Ulang Tahun"     styleClass="footer-link"/>
                <Label text="Photobooth Wisuda"          styleClass="footer-link"/>
                <Label text="Photobooth Corporate"       styleClass="footer-link"/>
                <Label text="AI Photobooth"              styleClass="footer-link"/>
            </VBox>

            <!-- Kontak -->
            <VBox spacing="10" HBox.hgrow="ALWAYS">
                <Label text="KONTAK" styleClass="footer-heading"/>
                <Label text="📍  Jl. Kebon Jeruk Raya No. 12, Jakarta Barat 11530"
                       styleClass="footer-link" wrapText="true" maxWidth="200"/>
                <Label text="📞  +62 812-3456-7890"        styleClass="footer-link"/>
                <Label text="✉  halo@AksafPhotobooth.id"         styleClass="footer-link"/>
                <Label text="⏰  Senin–Minggu, 08.00–20.00 WIB" styleClass="footer-link"/>
            </VBox>
        </HBox>

        <!-- Footer Bottom -->
        <HBox styleClass="footer-bottom" alignment="CENTER">
            <padding><Insets top="16" bottom="16"/></padding>
            <Label text="© 2026 Aksaf Photobooth. Semua hak dilindungi." styleClass="footer-copy"/>
        </HBox>

    </VBox>
</ScrollPane>
