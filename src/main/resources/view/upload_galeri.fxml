<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.Separator?>
<?import javafx.geometry.Insets?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.UploadGaleriController"
      prefWidth="1280" prefHeight="800"
      styleClass="admin-root">

    <!-- SIDEBAR KIRI -->
    <VBox styleClass="sidebar" prefWidth="240" minWidth="240" spacing="0">

        <VBox styleClass="sidebar-logo-box" alignment="CENTER_LEFT" spacing="4">
            <Label text="Aksaf" styleClass="sidebar-logo-text"/>
            <Label text="Photobooth" styleClass="sidebar-logo-sub"/>
        </VBox>

        <Separator styleClass="sidebar-sep"/>

        <Label text="MENU UTAMA" styleClass="sidebar-section-label">
            <VBox.margin><Insets top="20" left="20" bottom="8" right="0"/></VBox.margin>
        </Label>

        <HBox styleClass="sidebar-menu-item" alignment="CENTER_LEFT" spacing="12"
              onMouseClicked="#goDashboard">
            <Label text="Dashboard" styleClass="sidebar-menu-label" mouseTransparent="true"/>
        </HBox>

        <HBox styleClass="sidebar-menu-item" alignment="CENTER_LEFT" spacing="12"
              onMouseClicked="#goKelolaPesanan">
            <Label text="Kelola Pesanan" styleClass="sidebar-menu-label" mouseTransparent="true"/>
        </HBox>

        <HBox styleClass="sidebar-menu-item" alignment="CENTER_LEFT" spacing="12"
              onMouseClicked="#goKelolaPaket">
            <Label text="Kelola Paket" styleClass="sidebar-menu-label" mouseTransparent="true"/>
        </HBox>

        <!-- Upload Galeri (aktif) -->
        <HBox styleClass="sidebar-menu-item-active" alignment="CENTER_LEFT" spacing="12">
            <Label text="Upload Galeri" styleClass="sidebar-menu-label" mouseTransparent="true"/>
        </HBox>

        <HBox styleClass="sidebar-menu-item" alignment="CENTER_LEFT" spacing="12"
              onMouseClicked="#goKalender">
            <Label text="Kalender Booking" styleClass="sidebar-menu-label" mouseTransparent="true"/>
        </HBox>

        <HBox styleClass="sidebar-menu-item" alignment="CENTER_LEFT" spacing="12"
              onMouseClicked="#goPelanggan">
            <Label text="Pelanggan" styleClass="sidebar-menu-label" mouseTransparent="true"/>
        </HBox>

        <Button text="Logout" onAction="#handleLogout"
                styleClass="sidebar-logout-btn" maxWidth="Infinity"/>

        <Region VBox.vgrow="ALWAYS"/>

        <VBox styleClass="sidebar-bottom-section" spacing="0">
            <Separator styleClass="sidebar-sep"/>
            <HBox styleClass="sidebar-profile-box" alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="sidebar-avatar" minWidth="36" minHeight="36"
                           prefWidth="36" prefHeight="36">
                    <Label fx:id="labelAdminInitial" styleClass="sidebar-avatar-initial"/>
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="labelAdminName" text="Admin" styleClass="sidebar-profile-name"/>
                    <Label fx:id="labelAdminRole" text="Administrator" styleClass="sidebar-profile-role"/>
                </VBox>
            </HBox>
        </VBox>

    </VBox>

    <!-- KONTEN UTAMA -->
    <ScrollPane HBox.hgrow="ALWAYS" fitToWidth="true" hbarPolicy="NEVER"
                style="-fx-background-color: transparent; -fx-background: transparent;">
        <VBox styleClass="main-content" spacing="0">

            <VBox styleClass="content-header" spacing="4">
                <Label text="Upload Galeri" styleClass="page-title"/>
                <Label text="Kelola foto dan album galeri Aksaf Photobooth."
                       styleClass="page-subtitle"/>
            </VBox>

            <!-- FORM TAMBAH GALERI -->
            <VBox styleClass="form-section" spacing="16">
                <VBox.margin><Insets top="32" right="40" bottom="0" left="40"/></VBox.margin>

                <Label text="Tambah Item Galeri" styleClass="section-heading"/>
                <Label text="Isi detail foto atau album yang ingin ditampilkan di galeri."
                       styleClass="section-subheading"/>

                <!-- Baris 1: Judul + Kategori -->
                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Judul Album / Foto" styleClass="form-label"/>
                        <TextField fx:id="fieldJudul" promptText="contoh: Wedding Budi &amp; Ani"
                                   styleClass="form-input"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Kategori" styleClass="form-label"/>
                        <ComboBox fx:id="comboKategori" maxWidth="Infinity" styleClass="form-input"/>
                    </VBox>
                </HBox>

                <!-- Baris 2: Tanggal + Jumlah Foto -->
                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Tanggal Event" styleClass="form-label"/>
                        <TextField fx:id="fieldTanggal" promptText="contoh: 09 Mei 2026"
                                   styleClass="form-input"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Jumlah Foto" styleClass="form-label"/>
                        <TextField fx:id="fieldJumlahFoto" promptText="contoh: 120"
                                   styleClass="form-input"/>
                    </VBox>
                </HBox>

                <!-- Link Galeri -->
                <VBox spacing="6">
                    <Label text="Link Galeri Online (opsional)" styleClass="form-label"/>
                    <TextField fx:id="fieldLink" promptText="https://..."
                               styleClass="form-input"/>
                </VBox>

                <!-- Pilih File -->
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Button text="📁 Pilih Foto Cover" onAction="#handlePilihFile"
                            styleClass="btn-pilih-file"/>
                    <Label fx:id="labelFilePath" text="Belum ada file dipilih"
                           styleClass="file-path-label"/>
                </HBox>

                <!-- Tombol Aksi -->
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Button text="✓ Simpan ke Galeri" onAction="#handleSimpan"
                            styleClass="btn-simpan"/>
                    <Button text="🗑 Hapus Terpilih" onAction="#handleHapus"
                            styleClass="btn-hapus"/>
                </HBox>

                <Label fx:id="labelStatus" text="" styleClass="status-label"/>
            </VBox>

            <!-- TABEL DAFTAR GALERI -->
            <VBox styleClass="table-section" spacing="16">
                <VBox.margin><Insets top="32" right="40" bottom="40" left="40"/></VBox.margin>

                <HBox alignment="CENTER_LEFT">
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Daftar Item Galeri" styleClass="section-heading"/>
                        <Label text="Klik baris untuk memilih, lalu tekan Hapus Terpilih."
                               styleClass="section-subheading"/>
                    </VBox>
                </HBox>

                <TableView fx:id="tableGaleri" prefHeight="280" styleClass="booking-table">
                    <columns>
                        <TableColumn fx:id="colJudul"    text="Judul"         prefWidth="300" reorderable="false"/>
                        <TableColumn fx:id="colKategori" text="Kategori"      prefWidth="120" reorderable="false"/>
                        <TableColumn fx:id="colTanggal"  text="Tanggal"       prefWidth="130" reorderable="false"/>
                        <TableColumn fx:id="colJumlah"   text="Jumlah Foto"   prefWidth="120" reorderable="false"/>
                    </columns>
                    <placeholder>
                        <Label text="Belum ada data galeri." styleClass="table-placeholder"/>
                    </placeholder>
                </TableView>
            </VBox>

        </VBox>
    </ScrollPane>

</HBox>
