<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.layout.StackPane?>

<ScrollPane
    xmlns:fx="http://javafx.com/fxml"
    fx:controller="controller.BerandaController"
    fitToWidth="true"
    hbarPolicy="NEVER"
    vbarPolicy="AS_NEEDED"
    styleClass="scroll-root">

    <VBox styleClass="page-root">

        <HBox styleClass="navbar" alignment="CENTER_LEFT">
            <VBox styleClass="logo-box">
                <Label text="📷 PhotoBooth" styleClass="logo-title"/>
                <Label text="Studio" styleClass="logo-sub"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox styleClass="nav-links" spacing="28" alignment="CENTER">
                <Label text="Beranda" styleClass="nav-active"/>
                <Label text="Pricelist" styleClass="nav-link" onMouseClicked="#handlePricelist"/>
                <Label text="Galeri" styleClass="nav-link" onMouseClicked="#handleGaleri"/>
                <Label text="Pemesanan" styleClass="nav-link" onMouseClicked="#handlePemesanan"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox spacing="16" alignment="CENTER">
                <Button text="Login" styleClass="btn-masuk" onAction="#handleMasuk"/>
                <Button text="Sign in" styleClass="btn-masuk" onAction="#handleRegister"/>
            </HBox>
        </HBox>

        <VBox styleClass="hero" spacing="20">
            <HBox>
                <Label text="🔥  Promo Aktif! Diskon hingga 20%" styleClass="promo-badge"/>
            </HBox>
            <Label text="Sewa Photobooth Murah," styleClass="hero-title-white" wrapText="true"/>
            <Label text="Kenangan Tak Terlupakan" styleClass="hero-title-pink" wrapText="true"/>
            <Label styleClass="hero-subtitle" wrapText="true" maxWidth="560"
                   text="Operator profesional, props lengkap, hasil foto berkualitas tinggi untuk wedding, ulang tahun, wisuda, dan corporate event di Jabodetabek."/>
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="Mulai dari" styleClass="hero-price-label"/>
                <Label text="Rp1.250.000" styleClass="hero-price"/>
            </HBox>
            <HBox spacing="16" alignment="CENTER_LEFT">
                <Button text="📅  Pesan Sekarang" styleClass="btn-pesan" onAction="#handlePesan"/>
                <Button text="◎  Lihat Paket" styleClass="btn-lihat" onAction="#handleLihatPaket"/>
            </HBox>
            <HBox spacing="48" alignment="CENTER_LEFT" styleClass="stats-row">
                <VBox alignment="CENTER" spacing="4">
                    <Label text="500+" styleClass="stat-number"/>
                    <Label text="Event Sukses" styleClass="stat-label"/>
                </VBox>
                <VBox alignment="CENTER" spacing="4">
                    <Label text="4.9★" styleClass="stat-number"/>
                    <Label text="Rating Pelanggan" styleClass="stat-label"/>
                </VBox>
                <VBox alignment="CENTER" spacing="4">
                    <Label text="50+" styleClass="stat-number"/>
                    <Label text="Paket Tersedia" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>

        <VBox styleClass="promo-section" spacing="32" alignment="CENTER">
            <VBox alignment="CENTER" spacing="12">
                <Label text="Penawaran Terbatas" styleClass="section-badge"/>
                <Label text="Promo Spesial Bulan Ini" styleClass="section-title"/>
                <Label text="Jangan lewatkan penawaran terbaik kami. Pesan sekarang sebelum kehabisan!"
                       styleClass="section-subtitle" wrapText="true" maxWidth="500"/>
            </VBox>
            <HBox spacing="24" alignment="CENTER">
                
                <VBox styleClass="promo-card" spacing="0" prefWidth="300">
                    <VBox styleClass="card-img card-img-lebaran" minHeight="160" alignment="TOP_RIGHT">
                        <Label text="HEMAT 20%" styleClass="hemat-badge"/>
                    </VBox>
                    <VBox styleClass="card-body" spacing="10">
                        <Label text="Promo Lebaran Spesial" styleClass="card-title"/>
                        <Label wrapText="true" styleClass="card-desc"
                               text="Diskon 20% untuk semua paket cetak selama bulan April. Cocok untuk gathering keluarga dan acara Lebaran!"/>
                        <Label text="📅  1 Apr 2026 – 30 Apr 2026" styleClass="card-date"/>
                        <Button text="Ambil Promo" styleClass="btn-ambil" maxWidth="Infinity" onAction="#handleAmbilPromo1"/>
                    </VBox>
                </VBox>
                
                <VBox styleClass="promo-card" spacing="0" prefWidth="300">
                    <VBox styleClass="card-img card-img-wisuda" minHeight="160" alignment="TOP_RIGHT">
                        <Label text="HEMAT 15%" styleClass="hemat-badge"/>
                    </VBox>
                    <VBox styleClass="card-body" spacing="10">
                        <Label text="Paket Wisuda Hemat" styleClass="card-title"/>
                        <Label wrapText="true" styleClass="card-desc"
                               text="Spesial wisuda semester ini! Dapatkan tambahan 50 lembar cetak gratis untuk setiap pemesanan."/>
                        <Label text="📅  15 Apr 2026 – 31 Mei 2026" styleClass="card-date"/>
                        <Button text="Ambil Promo" styleClass="btn-ambil" maxWidth="Infinity" onAction="#handleAmbilPromo2"/>
                    </VBox>
                </VBox>
                
                <VBox styleClass="promo-card" spacing="0" prefWidth="300">
                    <VBox styleClass="card-img card-img-wedding" minHeight="160" alignment="TOP_RIGHT">
                        <Label text="HEMAT 10%" styleClass="hemat-badge"/>
                    </VBox>
                    <VBox styleClass="card-body" spacing="10">
                        <Label text="Wedding Package Premium" styleClass="card-title"/>
                        <Label wrapText="true" styleClass="card-desc"
                               text="Paket pernikahan lengkap dengan backdrop mewah, operator berpengalaman, dan album foto eksklusif."/>
                        <Label text="📅  1 Apr 2026 – 30 Jun 2026" styleClass="card-date"/>
                        <Button text="Ambil Promo" styleClass="btn-ambil" maxWidth="Infinity" onAction="#handleAmbilPromo3"/>
                    </VBox>
                </VBox>
            </HBox>
        </VBox>

        <VBox styleClass="galeri-section" spacing="24">
            <!-- Header -->
            <HBox alignment="CENTER_LEFT">
                <VBox spacing="8">
                    <Label text="Galeri Kami" styleClass="section-badge"/>
                    <Label text="Momen yang Telah Kami Abadikan" styleClass="galeri-title"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Lihat Semua →" styleClass="lihat-semua" onMouseClicked="#handleGaleri"/>
            </HBox>

            <HBox spacing="16" alignment="CENTER_LEFT">

                <VBox styleClass="galeri-card" prefWidth="260">
                    <VBox styleClass="galeri-img galeri-img-wedding" minHeight="220" alignment="BOTTOM_LEFT">
                        <VBox styleClass="galeri-overlay" alignment="BOTTOM_LEFT">
                            <Label text="Wedding" styleClass="galeri-tag galeri-tag-pink"/>
                            <Label text="Wedding Lady &amp; Cortis" styleClass="galeri-name"/>
                            <Label text="148 foto" styleClass="galeri-count"/>
                        </VBox>
                    </VBox>
                </VBox>

                <VBox styleClass="galeri-card" prefWidth="260">
                    <VBox styleClass="galeri-img galeri-img-birthday" minHeight="220" alignment="BOTTOM_LEFT">
                        <VBox styleClass="galeri-overlay" alignment="BOTTOM_LEFT">
                            <Label text="Birthday" styleClass="galeri-tag galeri-tag-pink"/>
                            <Label text="Ulang Tahun dea ke-7" styleClass="galeri-name"/>
                            <Label text="92 foto" styleClass="galeri-count"/>
                        </VBox>
                    </VBox>
                </VBox>

                <VBox styleClass="galeri-card" prefWidth="260">
                    <VBox styleClass="galeri-img galeri-img-corporate" minHeight="220" alignment="BOTTOM_LEFT">
                        <VBox styleClass="galeri-overlay" alignment="BOTTOM_LEFT">
                            <Label text="Corporate" styleClass="galeri-tag galeri-tag-purple"/>
                            <Label text="Gathering PT Maju Bersama" styleClass="galeri-name"/>
                            <Label text="215 foto" styleClass="galeri-count"/>
                        </VBox>
                    </VBox>
                </VBox>

                <VBox styleClass="galeri-card" prefWidth="260">
                    <VBox styleClass="galeri-img galeri-img-wisuda2" minHeight="220" alignment="BOTTOM_LEFT">
                        <VBox styleClass="galeri-overlay" alignment="BOTTOM_LEFT">
                            <Label text="Wisuda" styleClass="galeri-tag galeri-tag-blue"/>
                            <Label text="Wisuda Universitas sriwijaya" styleClass="galeri-name"/>
                            <Label text="176 foto" styleClass="galeri-count"/>
                        </VBox>
                    </VBox>
                </VBox>

            </HBox>
        </VBox>

        <VBox styleClass="testimoni-section" spacing="32" alignment="CENTER">
            <VBox alignment="CENTER" spacing="12">
                <Label text="Kata Mereka" styleClass="section-badge"/>
                <Label text="Testimoni Pelanggan" styleClass="section-title"/>
                <Label text="Ribuan pelanggan telah mempercayakan momen spesial mereka kepada kami."
                       styleClass="section-subtitle" wrapText="true" maxWidth="500"/>
            </VBox>

            <HBox spacing="20" alignment="CENTER">

                <VBox styleClass="testi-card" spacing="12" prefWidth="280">
                    <Label text="⭐⭐⭐⭐⭐" styleClass="testi-stars"/>
                    <Label wrapText="true" styleClass="testi-text"
                           text="Pelayanannya sangat profesional! Foto-foto hasilnya bagus banget, props-nya juga lengkap. Pasti bakal sewa lagi!"/>
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Label text="👤" styleClass="testi-avatar"/>
                        <VBox spacing="2">
                            <Label text="Cindy nabila" styleClass="testi-name"/>
                            <Label text="Wedding, April 2026" styleClass="testi-event"/>
                        </VBox>
                    </HBox>
                </VBox>

                <VBox styleClass="testi-card" spacing="12" prefWidth="280">
                    <Label text="⭐⭐⭐⭐⭐" styleClass="testi-stars"/>
                    <Label wrapText="true" styleClass="testi-text"
                           text="Sangat puas! Operator ramah dan sabar. Anak-anak senang banget foto-fotoan. Recommended banget!"/>
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Label text="👤" styleClass="testi-avatar"/>
                        <VBox spacing="2">
                            <Label text="Lady alfin" styleClass="testi-name"/>
                            <Label text="Birthday, Maret 2026" styleClass="testi-event"/>
                        </VBox>
                    </HBox>
                </VBox>

                <VBox styleClass="testi-card" spacing="12" prefWidth="280">
                    <Label text="⭐⭐⭐⭐⭐" styleClass="testi-stars"/>
                    <Label wrapText="true" styleClass="testi-text"
                           text="Untuk acara corporate kami, hasilnya memuaskan. Setup cepat, hasil foto keren, tamu-tamu senang semua!"/>
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Label text="👤" styleClass="testi-avatar"/>
                        <VBox spacing="2">
                            <Label text="Difanya" styleClass="testi-name"/>
                            <Label text="Corporate, Februari 2026" styleClass="testi-event"/>
                        </VBox>
                    </HBox>
                </VBox>

            </HBox>
        </VBox>

        <HBox styleClass="footer" alignment="CENTER">
            <Label text="© 2026 PhotoBooth Studio. All rights reserved." styleClass="footer-text"/>
        </HBox>

    </VBox>
</ScrollPane>
