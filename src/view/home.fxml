                        <Button text="Ambil Promo" styleClass="btn-ambil-promo" onAction="#ambilPromo"/>
                    </VBox>
                </VBox>

                <!-- Promo 3 -->
                <VBox styleClass="promo-card" spacing="0">
                    <StackPane prefHeight="180" alignment="TOP_RIGHT">
                       <ImageView fitWidth="300" fitHeight="180" preserveRatio="false">
            <image>
                <Image url="@images/promo3.jpg"/>
            </image>
        </ImageView>
                        <Label text="HEMAT 10%" styleClass="promo-badge-hemat" StackPane.alignment="TOP_RIGHT"/>
                    </StackPane>
                    <VBox spacing="8" style="-fx-padding: 16 16 16 16;">
