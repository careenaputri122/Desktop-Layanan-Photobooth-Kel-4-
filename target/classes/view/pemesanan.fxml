<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<ScrollPane
    xmlns:fx="http://javafx.com/fxml"
    fx:controller="controller.PemesananController"
    fitToWidth="true"
    hbarPolicy="NEVER"
    styleClass="root-scroll"
    stylesheets="@pemesanan.css">

    <VBox spacing="0">

        <!-- ══════════════════════════════════════
             NAVBAR
             ══════════════════════════════════════ -->
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="0">
            <HBox styleClass="navbar-brand-box" alignment="CENTER_LEFT" spacing="8">
                <Label text="📷" styleClass="navbar-logo-icon"/>
                <Label text="Aksaf Photobooth" styleClass="navbar-brand"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox styleClass="navbar-menu-box" alignment="CENTER" spacing="4">
                <Button text="Beranda"   styleClass="nav-link"        onAction="#goHome"/>
                <Button text="Pricelist" styleClass="nav-link"        onAction="#goPricelist"/>
                <Button text="Galeri"    styleClass="nav-link"        onAction="#goGaleri"/>
                <Button text="Pemesanan" styleClass="nav-link-active" onAction="#goPemesanan"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox fx:id="authBox" styleClass="navbar-auth-box" alignment="CENTER_RIGHT" spacing="12"/>
        </HBox>

        <!-- ══════════════════════════════════════
             HEADER
             ══════════════════════════════════════ -->
        <VBox styleClass="page-header" alignment="CENTER" spacing="8">
            <padding><Insets top="48" bottom="32" left="20" right="20"/></padding>
            <Label text="Formulir Pemesanan" styleClass="page-title"/>
            <Label text="Ikuti langkah-langkah berikut untuk memesan photobooth impianmu"
                   styleClass="page-subtitle" wrapText="true" textAlignment="CENTER"/>

            <!-- Step Indicator -->
            <HBox alignment="CENTER" spacing="0" styleClass="step-bar">
                <padding><Insets top="24"/></padding>
                <VBox alignment="CENTER" spacing="6">
                    <Label fx:id="stepCircle1" text="✓" styleClass="step-circle-active"/>
                    <Label fx:id="stepLabel1"  text="Pilih Paket" styleClass="step-label-active"/>
                </VBox>
                <Label fx:id="stepLine1" text="" styleClass="step-line"/>
                <VBox alignment="CENTER" spacing="6">
                    <Label fx:id="stepCircle2" text="2" styleClass="step-circle"/>
                    <Label fx:id="stepLabel2"  text="Tanggal &amp; Lokasi" styleClass="step-label"/>
                </VBox>
                <Label fx:id="stepLine2" text="" styleClass="step-line"/>
                <VBox alignment="CENTER" spacing="6">
                    <Label fx:id="stepCircle3" text="3" styleClass="step-circle"/>
                    <Label fx:id="stepLabel3"  text="Data Pemesan" styleClass="step-label"/>
                </VBox>
                <Label fx:id="stepLine3" text="" styleClass="step-line"/>
                <VBox alignment="CENTER" spacing="6">
                    <Label fx:id="stepCircle4" text="4" styleClass="step-circle"/>
                    <Label fx:id="stepLabel4"  text="Ringkasan" styleClass="step-label"/>
                </VBox>
            </HBox>
        </VBox>

        <!-- ══════════════════════════════════════
             CONTENT AREA
             ══════════════════════════════════════ -->
        <VBox styleClass="content-area">
            <padding><Insets top="32" bottom="48" left="80" right="80"/></padding>

            <!-- ── STEP 1: Pilih Paket ── -->
            <VBox fx:id="step1Panel" spacing="20">
                <Label text="Pilih Paket" styleClass="section-title"/>
                <VBox fx:id="paketListBox" spacing="20"/>
            </VBox>

            <!-- ── STEP 2: Tanggal & Lokasi ── -->
            <VBox fx:id="step2Panel" spacing="20" managed="false" visible="false">
                <Label text="Pilih Tanggal &amp; Lokasi" styleClass="section-title"/>
                <HBox spacing="24">
                    <!-- Kalender -->
                    <VBox fx:id="calendarBox" styleClass="calendar-card" spacing="12" HBox.hgrow="ALWAYS"/>

                    <!-- Jam Mulai -->
                    <VBox spacing="14" minWidth="280">
                        <Label text="Jam Mulai" styleClass="section-subtitle"/>
                        <VBox spacing="6">
                            <Label text="Masukkan jam mulai acara (format HH:mm)" styleClass="field-label"/>
                            <TextField fx:id="jamMulaiField"
                                       promptText="Contoh: 09:00"
                                       styleClass="input-field"/>
                            <Label text="⏰  Operasional: 08.00 – 20.00 WIB"
                                   styleClass="slot-time"/>
                        </VBox>

                        <Label text="Lokasi Acara" styleClass="section-subtitle"/>
                        <TextField fx:id="lokasiField" promptText="Masukkan alamat lengkap acara" styleClass="input-field"/>
                    </VBox>
                </HBox>

                <HBox spacing="12" alignment="CENTER_RIGHT">
                    <Button text="← Kembali"   styleClass="btn-back" onAction="#backToStep1"/>
                    <Button text="Lanjut →"    styleClass="btn-next" onAction="#goToStep3"/>
                </HBox>
            </VBox>

            <!-- ── STEP 3: Data Pemesan ── -->
            <VBox fx:id="step3Panel" spacing="20" managed="false" visible="false">
                <Label text="Data Pemesan" styleClass="section-title"/>
                <VBox styleClass="form-card" spacing="16">
                    <HBox spacing="16">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="Nama Lengkap" styleClass="field-label"/>
                            <TextField fx:id="namaDepanField" promptText="Nama Depan" styleClass="input-field"/>
                        </VBox>
                        
                    </HBox>
                    <VBox spacing="6">
                        <Label text="Email" styleClass="field-label"/>
                        <TextField fx:id="emailField" promptText="contoh@email.com" styleClass="input-field"/>
                    </VBox>
                    <VBox spacing="6">
                        <Label text="No. WhatsApp" styleClass="field-label"/>
                        <TextField fx:id="phoneField" promptText="08xx-xxxx-xxxx" styleClass="input-field"/>
                    </VBox>
                    <VBox spacing="6">
                        <Label text="Catatan Tambahan (opsional)" styleClass="field-label"/>
                        <TextArea fx:id="catatanField" promptText="Tema, dekorasi, atau permintaan khusus..." styleClass="input-field" prefRowCount="3"/>
                    </VBox>
                </VBox>
                <Label fx:id="errorStep3" text="" styleClass="label-error"/>
                <HBox spacing="12" alignment="CENTER_RIGHT">
                    <Button text="← Kembali" styleClass="btn-back" onAction="#backToStep2"/>
                    <Button text="Lanjut →"  styleClass="btn-next" onAction="#goToStep4"/>
                </HBox>
            </VBox>

            <!-- ── STEP 4: Ringkasan ── -->
            <!-- ── STEP 4: Ringkasan ── -->
<VBox fx:id="step4Panel" spacing="20" managed="false" visible="false">
    <Label text="Ringkasan Pesanan" styleClass="section-title"/>
    <HBox spacing="20" alignment="TOP_LEFT">

        <!-- Kiri: Detail -->
        <VBox spacing="12" HBox.hgrow="ALWAYS">
            <!-- Paket -->
            <VBox styleClass="ring-card" spacing="4">
                <Label text="Paket Dipilih" styleClass="ring-card-label"/>
                <Label fx:id="ringPaket"    styleClass="ring-card-value"/>
                <Label fx:id="ringTipe"     styleClass="ring-card-sub"/>
            </VBox>
            <!-- Tanggal -->
            <VBox styleClass="ring-card" spacing="4">
                <Label text="Tanggal &amp; Waktu" styleClass="ring-card-label"/>
                <Label fx:id="ringTanggal"        styleClass="ring-card-value"/>
                <Label fx:id="ringJamMulai"       styleClass="ring-card-sub"/>
            </VBox>
            <!-- Lokasi -->
            <VBox styleClass="ring-card" spacing="4">
                <Label text="Lokasi Event"  styleClass="ring-card-label"/>
                <Label fx:id="ringLokasi"   styleClass="ring-card-value" wrapText="true"/>
            </VBox>
            <!-- Data Pemesan -->
            <VBox styleClass="ring-card" spacing="4">
                <Label text="Data Pemesan"  styleClass="ring-card-label"/>
                <Label fx:id="ringNama"     styleClass="ring-card-value"/>
                <Label fx:id="ringContact"  styleClass="ring-card-sub"/>
            </VBox>
        </VBox>

        <!-- Kanan: Total Pembayaran -->
        <VBox styleClass="payment-card" spacing="14" minWidth="300" maxWidth="340">
            <Label text="Total Pembayaran" styleClass="payment-title"/>
            <HBox>
                <Label text="Harga Paket"    styleClass="pay-key" HBox.hgrow="ALWAYS"/>
                <Label fx:id="payHarga"      styleClass="pay-val"/>
            </HBox>
            <HBox fx:id="diskonRow" managed="false" visible="false">
                <Label text="Promo/Diskon"  styleClass="pay-key" HBox.hgrow="ALWAYS"/>
                <Label fx:id="payDiskon"     styleClass="pay-diskon"/>
            </HBox>
            <Label styleClass="divider-line" maxWidth="Infinity"/>
            <HBox>
                <Label text="Total"          styleClass="pay-total-key" HBox.hgrow="ALWAYS"/>
                <Label fx:id="payTotal"      styleClass="pay-total-val"/>
            </HBox>
            
            <Button fx:id="btnKonfirmasi" text="Konfirmasi Pesanan" styleClass="btn-konfirmasi"
                    onAction="#konfirmasi" maxWidth="Infinity"/>
        </VBox>

    </HBox>
    <Button text="← Kembali" styleClass="btn-back" onAction="#backToStep3"/>
</VBox>
        </VBox>

        <!-- ══════════════════════════════════════
             FOOTER
             ══════════════════════════════════════ -->
        <HBox styleClass="footer" spacing="60" alignment="TOP_LEFT">
            <padding><Insets top="50" bottom="50" left="80" right="80"/></padding>
            <VBox spacing="12" HBox.hgrow="ALWAYS" maxWidth="220">
                <Label text="📷 Aksaf Photobooth" styleClass="footer-brand"/>
                <Label text="Sewa photobooth terjangkau untuk momen spesialmu. Operator profesional, hasil foto berkualitas, kenangan tak terlupakan."
                       styleClass="footer-desc" wrapText="true"/>
            </VBox>
            <VBox spacing="10" HBox.hgrow="ALWAYS">
                <Label text="LINK CEPAT"       styleClass="footer-heading"/>
                <Label text="Beranda"          styleClass="footer-link"/>
                <Label text="Pricelist"        styleClass="footer-link"/>
                <Label text="Galeri Foto"      styleClass="footer-link"/>
                <Label text="Kalender Booking" styleClass="footer-link"/>
            </VBox>
            <VBox spacing="10" HBox.hgrow="ALWAYS">
                <Label text="LAYANAN"                    styleClass="footer-heading"/>
                <Label text="Photobooth Wedding"         styleClass="footer-link"/>
                <Label text="Photobooth Ulang Tahun"     styleClass="footer-link"/>
                <Label text="Photobooth Wisuda"          styleClass="footer-link"/>
                <Label text="Photobooth Corporate"       styleClass="footer-link"/>
            </VBox>
            <VBox spacing="10" HBox.hgrow="ALWAYS">
                <Label text="KONTAK" styleClass="footer-heading"/>
                <Label text="📍  Jl. Kebon Jeruk Raya No. 12, Jakarta Barat 11530" styleClass="footer-link" wrapText="true" maxWidth="200"/>
                <Label text="📞  +62 812-3456-7890"        styleClass="footer-link"/>
                <Label text="✉  halo@aksafPhotobooth.id"         styleClass="footer-link"/>
                <Label text="⏰  Senin–Minggu, 08.00–20.00 WIB" styleClass="footer-link"/>
            </VBox>
        </HBox>
        <HBox styleClass="footer-bottom" alignment="CENTER">
            <padding><Insets top="16" bottom="48"/></padding>
            <Label text="© 2026 Aksaf Photobooth. Semua hak dilindungi." styleClass="footer-copy"/>
        </HBox>

    </VBox>
</ScrollPane>
