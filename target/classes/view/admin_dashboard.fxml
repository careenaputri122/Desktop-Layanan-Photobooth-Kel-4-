<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.Separator?>
<?import javafx.geometry.Insets?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.AdminDashboardController"
      prefWidth="1280" prefHeight="800"
      styleClass="admin-root">

    <!-- ══════════════════════════════════════
         SIDEBAR KIRI
         ══════════════════════════════════════ -->
    <VBox styleClass="sidebar" prefWidth="240" minWidth="240" spacing="0">

        <!-- Logo -->
        <VBox styleClass="sidebar-logo-box" alignment="CENTER_LEFT" spacing="4">
            <Label text="📷 Aksaf" styleClass="sidebar-logo-text"/>
            <Label text="Photobooth" styleClass="sidebar-logo-sub"/>
        </VBox>

        <Separator styleClass="sidebar-sep"/>

        <!-- Label Seksi -->
        <Label text="MENU UTAMA" styleClass="sidebar-section-label">
            <VBox.margin><Insets top="20" left="20" bottom="8" right="0"/></VBox.margin>
        </Label>

        <!-- Dashboard (aktif) -->
        <HBox styleClass="sidebar-menu-item-active" alignment="CENTER_LEFT" spacing="12">
            <Label text="📊" styleClass="sidebar-menu-icon"/>
            <Label text="Dashboard" styleClass="sidebar-menu-label"/>
        </HBox>

        <!-- Kelola Pesanan -->
        <HBox styleClass="sidebar-menu-item" alignment="CENTER_LEFT" spacing="12"
              onMouseClicked="#goKelolaPesanan">
            <Label text="📋" styleClass="sidebar-menu-icon"/>
            <Label text="Kelola Pesanan" styleClass="sidebar-menu-label"/>
        </HBox>

        <!-- Kelola Paket -->
        <HBox styleClass="sidebar-menu-item" alignment="CENTER_LEFT" spacing="12"
              onMouseClicked="#goKelolaPaket">
            <Label text="📦" styleClass="sidebar-menu-icon"/>
            <Label text="Kelola Paket" styleClass="sidebar-menu-label"/>
        </HBox>

        <!-- Upload Galeri -->
        <HBox styleClass="sidebar-menu-item" alignment="CENTER_LEFT" spacing="12"
              onMouseClicked="#goUploadGaleri">
            <Label text="🖼️" styleClass="sidebar-menu-icon"/>
            <Label text="Upload Galeri" styleClass="sidebar-menu-label"/>
        </HBox>

        <!-- Kalender Booking -->
        <HBox styleClass="sidebar-menu-item" alignment="CENTER_LEFT" spacing="12"
              onMouseClicked="#goKalender">
            <Label text="📅" styleClass="sidebar-menu-icon"/>
            <Label text="Kalender Booking" styleClass="sidebar-menu-label"/>
        </HBox>

        <!-- Pelanggan -->
        <HBox styleClass="sidebar-menu-item" alignment="CENTER_LEFT" spacing="12"
              onMouseClicked="#goPelanggan">
            <Label text="👥" styleClass="sidebar-menu-icon"/>
            <Label text="Pelanggan" styleClass="sidebar-menu-label"/>
        </HBox>
         <Button fx:id="btnLogout" text="🚪  Logout"
                    onAction="#handleLogout"
                    styleClass="sidebar-logout-btn"
                    maxWidth="Infinity"/>

        <!-- Spacer -->
        <Region VBox.vgrow="ALWAYS"/>

        <!-- Bottom Section: Profile + Logout -->
        <VBox styleClass="sidebar-bottom-section" spacing="0">
            <Separator styleClass="sidebar-sep"/>

            <!-- Profile Admin -->
            <HBox styleClass="sidebar-profile-box" alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="sidebar-avatar" minWidth="36" minHeight="36"
                           prefWidth="36" prefHeight="36">
                    <Label fx:id="labelAdminInitial" styleClass="sidebar-avatar-initial"/>
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="labelAdminName" text="Admin" styleClass="sidebar-profile-name"/>
                    <Label fx:id="labelAdminRole" text="Administrator" styleClass="sidebar-profile-role"/>
                </VBox>
            </HBox>

           
        </VBox>

    </VBox>

    <!-- ══════════════════════════════════════
         KONTEN UTAMA (kanan)
         ══════════════════════════════════════ -->
    <ScrollPane HBox.hgrow="ALWAYS" fitToWidth="true" hbarPolicy="NEVER"
                style="-fx-background-color: transparent; -fx-background: transparent;">
        <VBox styleClass="main-content" spacing="0">

            <!-- Header halaman -->
            <VBox styleClass="content-header" spacing="4">
                <Label text="Dashboard" styleClass="page-title"/>
                <Label text="Selamat datang kembali! Berikut ringkasan aktivitas hari ini."
                       styleClass="page-subtitle"/>
            </VBox>

            <!-- ── STAT CARDS ── -->
            <HBox styleClass="stat-row" spacing="20">
                <VBox.margin><Insets top="32" right="40" bottom="0" left="40"/></VBox.margin>

                <!-- Pesanan Hari Ini -->
                <VBox styleClass="stat-card" spacing="10" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="0">
                        <Label text="Pesanan Hari Ini" styleClass="stat-card-label" HBox.hgrow="ALWAYS"/>
                        <StackPane styleClass="stat-icon-box stat-icon-pink">
                            <Label text="📋" styleClass="stat-icon"/>
                        </StackPane>
                    </HBox>
                    <Label fx:id="labelPesananHariIni" text="0" styleClass="stat-card-number"/>
                    <Label text="pesanan masuk hari ini" styleClass="stat-card-desc"/>
                </VBox>

                <!-- Member Aktif -->
                <VBox styleClass="stat-card" spacing="10" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="0">
                        <Label text="Member Aktif" styleClass="stat-card-label" HBox.hgrow="ALWAYS"/>
                        <StackPane styleClass="stat-icon-box stat-icon-blue">
                            <Label text="👤" styleClass="stat-icon"/>
                        </StackPane>
                    </HBox>
                    <Label fx:id="labelMemberAktif" text="0" styleClass="stat-card-number stat-number-blue"/>
                    <Label text="pengguna terdaftar" styleClass="stat-card-desc"/>
                </VBox>

                <!-- Pesanan Pending -->
                <VBox styleClass="stat-card" spacing="10" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="0">
                        <Label text="Pesanan Pending" styleClass="stat-card-label" HBox.hgrow="ALWAYS"/>
                        <StackPane styleClass="stat-icon-box stat-icon-yellow">
                            <Label text="⏳" styleClass="stat-icon"/>
                        </StackPane>
                    </HBox>
                    <Label fx:id="labelPesananPending" text="0" styleClass="stat-card-number stat-number-yellow"/>
                    <Label text="menunggu konfirmasi" styleClass="stat-card-desc"/>
                </VBox>

            </HBox>

            <!-- ── TABEL PESANAN TERBARU ── -->
            <VBox styleClass="table-section" spacing="16">
                <VBox.margin><Insets top="32" right="40" bottom="40" left="40"/></VBox.margin>

                <HBox alignment="CENTER_LEFT">
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Pesanan Terbaru" styleClass="section-heading"/>
                        <Label text="5 pesanan paling baru" styleClass="section-subheading"/>
                    </VBox>
                </HBox>

                <TableView fx:id="tableBooking" prefHeight="280" styleClass="booking-table">
                    <columns>
                        <TableColumn fx:id="colNomor"       text="No. Pesanan"   prefWidth="150" reorderable="false"/>
                        <TableColumn fx:id="colNamaPemesan" text="Nama Pemesan"  prefWidth="180" reorderable="false"/>
                        <TableColumn fx:id="colPaket"       text="Paket"         prefWidth="150" reorderable="false"/>
                        <TableColumn fx:id="colTanggal"     text="Tanggal Event" prefWidth="130" reorderable="false"/>
                        <TableColumn fx:id="colStatus"      text="Status"        prefWidth="120" reorderable="false"/>
                        <TableColumn fx:id="colTotal"       text="Total Harga"   prefWidth="150" reorderable="false"/>
                    </columns>
                    <placeholder>
                        <Label text="Belum ada data pesanan." styleClass="table-placeholder"/>
                    </placeholder>
                </TableView>
            </VBox>

        </VBox>
    </ScrollPane>

</HBox>
